---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="ru">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Уютная кофейня" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
		
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&family=Playfair+Display:ital,wght@0,700;1,400&display=swap" rel="stylesheet">
		
		<script src="https://unpkg.com/lucide@latest"></script>
	</head>
	<body>
		<slot />
		
		<script>
			// Инициализация иконок Lucide после загрузки страницы
			declare let lucide: any;
			lucide.createIcons();
		</script>
	</body>
</html>

<style is:global>
	:root {
		--bg-color: #faf7f2;
		--text-dark: #2c1b18;
		--accent: #8c6239;
		--accent-light: #e6ccb2;
	}
	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}
	body {
		font-family: 'Montserrat', sans-serif;
		background-color: var(--bg-color);
		color: var(--text-dark);
		line-height: 1.6;
	}
	h1, h2, h3 {
		font-family: 'Playfair Display', serif;
	}
</style>
